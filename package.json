{
  "name": "vivace-bingo-card",
  "version": "1.0.0",
  "description": "VIVACE 2026 Stamp Card — SMU CCA Fair",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "predev": "pkill -f 'nodemon server.js' 2>/dev/null; pkill -f 'node server.js' 2>/dev/null; true",
    "dev": "nodemon server.js",
    "kill": "pkill -f 'nodemon server.js' 2>/dev/null; pkill -f 'node server.js' 2>/dev/null; true",
    "build":         "node scripts/build.js",
    "vercel-build":  "node scripts/build.js",
    "postinstall":   "node scripts/build.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "ejs": "^3.1.10",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "terser": "^5.31.0"
  },
  "nodemon": {
    "watch": ["server.js", "routes", "models", "views", "utils", "controllers"],
    "ignore": ["node_modules", "public"],
    "ext": "js,ejs,json"
  }
}
