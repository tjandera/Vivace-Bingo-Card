<%#
    index.ejs — Main (and only) page template.
    The whole app renders here on first load; everything after is client-side JS.
    Structure lives in partials/ — edit those to change specific sections.
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>

    <%- include('partials/login')  %>
    <%- include('partials/card')   %>
    <%- include('partials/modals') %>

    <!-- Server-side data handed off to client-side JS -->
    <script>
        const BOOTH_CODES          = <%- JSON.stringify(boothCodes)         %>;
        const TOTAL_BOOTHS         = <%=  totalBooths                       %>;
        const PRIZE_CONFIG         = <%- JSON.stringify(prizeConfig)        %>;
        const MANDATORY_BOOTH_ID   = <%- JSON.stringify(mandatoryBoothId)   %>;
        const MANDATORY_BOOTH_NAME = <%- JSON.stringify(mandatoryBoothName) %>;
    </script>

    <!-- Client-side modules — load order matters -->
    <script src="/js/state.js"></script>
    <script src="/js/ui.js"></script>
    <script src="/js/install.js"></script>
    <script src="/js/app.js"></script>

</body>
</html>
