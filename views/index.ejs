<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>

<!-- LOGIN OVERLAY — shown on first visit, hidden by JS after name is entered -->
<div id="loginOverlay" class="login-overlay" role="dialog" aria-modal="true" aria-labelledby="loginHeading">
    <div class="login-card">
        <h2 id="loginHeading" class="sr-only">VIVACE 2026 Stamp Card — Enter your name to begin</h2>
        <img src="/images/vivace-logo.png" alt="VIVACE 2026" class="login-logo">

        <div class="rules-block rules-block--login">
            <div class="rules-title">How it works</div>
            <ol class="rules-list">
                <li>Collect codes by visiting the required booths. <em>Hint: each circle's colour shows which cluster the booth belongs to and where to find it on the map.</em></li>
                <li>After visiting the booth, the CCA representative will input the code onto your phone.</li>
                <li>Earn a prize after every 3 checkpoints — head to the registration booth to claim your prize!</li>
            </ol>
        </div>

        <label class="login-label" for="loginInput">Enter your name to begin</label>
        <input type="text" id="loginInput" class="login-input" placeholder="e.g. Alex Tan" autocomplete="off" maxlength="30">
        <button id="loginBtn" class="login-btn" onclick="handleLogin()">Let's Go</button>
        <div id="loginError" class="login-error"></div>

        <div class="login-notice">
            <span class="notice-icon">⚠️</span>
            <div>
                Your stamp progress is saved in <strong>this browser only</strong>.
                Switching devices, clearing your browser data, or using incognito mode will reset your card.
            </div>
        </div>
    </div>
</div>

<div class="card-wrapper">
    <div class="card">

        <!-- HEADER -->
        <div class="card-header">
            <img src="/images/vivace-logo.png" alt="VIVACE 2026" class="header-logo">
        </div>

        <!-- PARTICIPANT -->
        <div class="participant-section">
            <span class="participant-label">Cardholder</span>
            <div class="participant-name-row">
                <span id="nameDisplay">—</span>
                <button class="switch-btn" id="switchUserBtn" title="Switch user">Switch</button>
            </div>
        </div>

        <!-- PROGRESS -->
        <div class="progress-area">
            <div class="progress-text">Booths visited: <span id="progressCount">0</span> / <%= totalBooths %></div>
            <div class="progress-bar-bg"
                 role="progressbar"
                 aria-valuemin="0"
                 aria-valuemax="<%= totalBooths %>"
                 aria-valuenow="0"
                 aria-label="Booths visited"
                 id="progressBar">
                <div class="progress-fill" id="progressFill"></div>
            </div>
        </div>

        <!-- BOOTH GRID -->
        <div class="checkpoint-grid">
            <% booths.forEach(function(booth, i) { %>
            <div class="checkpoint-card<%= booth.mandatory ? ' mandatory' : '' %>"
                 style="--accent:<%= booth.accent %>"
                 data-id="<%= booth.id %>"
                 data-name="<%= booth.name %>"
                 data-logo="<%= booth.logo %>"
                 <% if (booth.mandatory) { %>data-mandatory="true"<% } %>
                 onclick="handleBoothClick(this)">
                <% if (booth.mandatory) { %><div class="mandatory-badge">START HERE</div><% } %>
                <img class="checkpoint-icon"
                     src="<%= booth.logo %>"
                     alt="<%= booth.name %>"
                     style="animation-delay:<%= (i * 0.38).toFixed(2) %>s">
                <div class="checkpoint-name"><%= booth.name %></div>
                <div class="lock-overlay" aria-hidden="true">🔒</div>
            </div>
            <% }); %>
        </div>

        <!-- PRIZES -->
        <div class="prize-section">
            <div class="prize-title">Prizes</div>
            <div class="prize-grid">
                <% prizes.forEach(function(prize) { %>
                <div class="prize-circle" data-prize="<%= prize.id %>" onclick="handlePrizeClick(<%= prize.id %>)">
                    <div class="prize-icon"><%= prize.icon %></div>
                    <div class="prize-label"><%= prize.stampsRequired %> stamps</div>
                    <div class="prize-req"><%= prize.label %></div>
                </div>
                <% }); %>
            </div>
        </div>

        <!-- RULES (persistent while playing) -->
        <div class="rules-section">
            <div class="rules-title">How it works</div>
            <ol class="rules-list">
                <li>Collect codes by visiting the required booths. <em>Hint: each circle's colour shows which cluster the booth belongs to and where to find it on the map.</em></li>
                <li>After visiting the booth, the CCA representative will input the code onto your phone.</li>
                <li>Earn a prize after every 3 checkpoints — head to the registration booth to claim your prize!</li>
            </ol>
        </div>

    </div>
</div>

<!-- CONFETTI CANVAS -->
<canvas id="confettiCanvas" style="position:fixed;top:0;right:0;bottom:0;left:0;pointer-events:none;z-index:9997;display:none;" aria-hidden="true"></canvas>

<!-- CONGRATS MODAL -->
<div id="congratsModal" class="modal congrats-modal" role="dialog" aria-modal="true" aria-labelledby="congratsTitle">
    <div class="modal-content congrats-content">
        <div class="congrats-emoji" aria-hidden="true">🎉</div>
        <img src="/images/vivace-logo.png" alt="VIVACE 2026" class="congrats-logo">
        <h2 id="congratsTitle" class="congrats-title">You Did It!</h2>
        <p class="congrats-text">You've visited all 12 booths — head to the prize counter to claim your reward!</p>
        <button class="btn-verify congrats-btn" id="congratsCloseBtn">Claim My Prize</button>
    </div>
</div>

<!-- CONFIRM MODAL -->
<div id="confirmModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="confirmText">
    <div class="modal-content">
        <p id="confirmText" class="confirm-message"></p>
        <div class="modal-buttons">
            <button class="btn-verify" id="confirmOkBtn">Confirm</button>
            <button class="btn-cancel"  id="confirmCancelBtn">Cancel</button>
        </div>
    </div>
</div>

<!-- CODE ENTRY MODAL -->
<div id="codeModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalCheckpointName">
    <div class="modal-content">
        <div class="modal-icon" id="modalIcon"></div>
        <h3 id="modalCheckpointName">Booth</h3>

        <div class="modal-map">
            <div class="modal-map-label">Find this booth on the map</div>
            <a href="#" class="map-link" id="mapLink" target="_blank" rel="noopener">
                <div class="map-image-box">
                    <img id="mapImage" src="" alt="VIVACE 2026 colour-coded venue map" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                    <div class="map-placeholder">
                        <span class="map-placeholder-icon">🗺️</span>
                        <span class="map-placeholder-text">Map image goes here</span>
                    </div>
                </div>
            </a>
            <div class="map-caption">Tap the map to open full size · 🍱 = food booths</div>
        </div>

        <p>Ask the CCA rep to enter the booth code:</p>
        <input type="text" id="codeInput" placeholder="enter code" autocomplete="off" maxlength="30">
        <div class="modal-buttons">
            <button class="btn-verify" id="modalConfirmBtn">Confirm</button>
            <button class="btn-cancel"  id="modalCancelBtn">Cancel</button>
        </div>
        <div id="modalError" class="modal-error"></div>
    </div>
</div>

<!-- TOAST NOTIFICATION -->
<div id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

<!-- SCREEN READER LIVE ANNOUNCER -->
<div id="liveAnnounce" class="sr-only" aria-live="polite" aria-atomic="true"></div>

<script>
    const BOOTH_CODES        = <%- JSON.stringify(boothCodes) %>;
    const TOTAL_BOOTHS       = <%= totalBooths %>;
    const PRIZE_CONFIG       = <%- JSON.stringify(prizeConfig) %>;
    const MANDATORY_BOOTH_ID = <%- JSON.stringify(mandatoryBoothId) %>;
    const MANDATORY_BOOTH_NAME = <%- JSON.stringify(mandatoryBoothName) %>;
</script>
<script src="/js/bingo.js"></script>

</body>
</html>
