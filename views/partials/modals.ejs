<%#
    modals.ejs — All overlays and floating UI elements:
      · Confetti canvas   (drawn by launchConfetti in ui.js when the card completes)
      · Congrats modal    (shown after visiting every booth)
      · Confirm modal     (generic yes/no prompt, used by prize redemption)
      · Code entry modal  (opens when a booth is tapped)
      · Toast             (small transient notifications)
      · Live announcer    (screen reader messages)
      · Install modal     (iOS "Add to Home Screen" instructions)
    Each modal is hidden by default and toggled via JS.
%>

<!-- CONFETTI CANVAS — full-screen, hidden until launchConfetti() draws on it -->
<canvas id="confettiCanvas" style="position:fixed;top:0;right:0;bottom:0;left:0;pointer-events:none;z-index:9997;display:none;" aria-hidden="true"></canvas>

<!-- CONGRATS MODAL — shown once all booths are stamped -->
<div id="congratsModal" class="modal congrats-modal" role="dialog" aria-modal="true" aria-labelledby="congratsTitle">
    <div class="modal-content congrats-content">
        <div class="congrats-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 21h8"/>
                <path d="M12 17v4"/>
                <path d="M7 4h10v5a5 5 0 0 1-10 0V4z"/>
                <path d="M17 4h3v3a3 3 0 0 1-3 3"/>
                <path d="M7 4H4v3a3 3 0 0 0 3 3"/>
            </svg>
        </div>
        <img src="/images/vivace-logo.png" alt="VIVACE 2026" class="congrats-logo">
        <h2 id="congratsTitle" class="congrats-title">You Did It!</h2>
        <p class="congrats-text">You've visited all <%= totalBooths %> booths — head to the prize counter to claim your reward!</p>
        <button class="btn-verify congrats-btn" id="congratsCloseBtn">Claim My Prize</button>
    </div>
</div>

<!-- REDEMPTION VOUCHER MODAL — shown after a prize is redeemed, or when
     the user taps an already-redeemed prize.  Serves as proof to be shown
     at the VIVACE prize counter.  Fields populated by UI.showRedemption(). -->
<div id="redeemModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="redeemTitle">
    <div class="modal-content voucher-content">
        <div class="voucher-stamp" aria-hidden="true">REDEEMED</div>
        <img src="/images/vivace-logo.png" alt="VIVACE 2026" class="voucher-brand-logo">
        <h3 id="redeemTitle" class="voucher-title">Prize Redemption Voucher</h3>
        <p class="voucher-subtitle">VIVACE 2026 · Open House</p>

        <div class="voucher-divider" aria-hidden="true"></div>

        <div class="voucher-row">
            <span class="voucher-row-label">Name</span>
            <span class="voucher-row-value" id="voucherName">—</span>
        </div>
        <div class="voucher-row">
            <span class="voucher-row-label">Stamps Collected</span>
            <span class="voucher-row-value" id="voucherStamps">—</span>
        </div>
        <div class="voucher-row">
            <span class="voucher-row-label">Issued</span>
            <span class="voucher-row-value" id="voucherIssued">—</span>
        </div>

        <div class="voucher-divider" aria-hidden="true"></div>

        <div class="voucher-prize">
            <img src="" alt="" class="voucher-prize-image" id="voucherPrizeImage">
            <div class="voucher-prize-meta">
                <div class="voucher-prize-label" id="voucherPrizeLabel">—</div>
                <div class="voucher-prize-note">Awarded upon completion of the required checkpoints</div>
            </div>
        </div>

        <div class="voucher-notice">
            <strong>Please present this voucher at the VIVACE prize counter to claim your reward.</strong>
            We kindly recommend taking a screenshot of this page. Your progress is saved on this device, but a screenshot ensures a smooth handover should any connectivity issues arise.
        </div>

        <div class="voucher-ref">Ref: <span id="voucherRef">—</span></div>

        <div class="modal-buttons">
            <button class="btn-verify" id="redeemCloseBtn">Close</button>
        </div>
    </div>
</div>

<!-- CONFIRM MODAL — generic yes/no prompt, driven by showConfirm() in ui.js -->
<div id="confirmModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="confirmText">
    <div class="modal-content">
        <p id="confirmText" class="confirm-message"></p>
        <div class="modal-buttons">
            <button class="btn-verify" id="confirmOkBtn">Confirm</button>
            <button class="btn-cancel"  id="confirmCancelBtn">Cancel</button>
        </div>
    </div>
</div>

<!-- CODE ENTRY MODAL — opens when a booth is tapped, asks the CCA rep for the code -->
<div id="codeModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalCheckpointName">
    <div class="modal-content">
        <div class="modal-icon" id="modalIcon"></div>
        <h3 id="modalCheckpointName">Booth</h3>

        <p>Ask the CCA rep to enter the booth code:</p>
        <input type="text" id="codeInput" placeholder="enter code" autocomplete="off" maxlength="30">
        <div class="modal-buttons">
            <button class="btn-verify" id="modalConfirmBtn">Confirm</button>
            <button class="btn-cancel"  id="modalCancelBtn">Cancel</button>
        </div>
        <div id="modalError" class="modal-error"></div>
    </div>
</div>

<!-- TOAST — small transient banner, driven by showToast() -->
<div id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

<!-- SCREEN READER LIVE REGION — announce() writes here for accessibility -->
<div id="liveAnnounce" class="sr-only" aria-live="polite" aria-atomic="true"></div>

<!-- INSTALL MODAL — iOS Add-to-Home-Screen instructions -->
<div id="installModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="installTitle">
    <div class="modal-content install-modal-content">
        <img src="/images/vivace-logo.png" alt="Vivace" class="install-logo">
        <h3 id="installTitle" class="install-title">Add to Home Screen</h3>
        <p class="install-subtitle" id="installSubtitle">Install Vivace as an app on your phone so you can open your stamp card in one tap.</p>

        <!-- iOS Safari steps — install.js shows this to iOS visitors -->
        <ol class="install-steps" id="installStepsIOS">
            <li class="install-step">
                <span class="install-step-num">1</span>
                <div class="install-step-body">
                    <div>Open this page in <strong>Safari</strong> (not Chrome or in-app browsers).</div>
                </div>
            </li>
            <li class="install-step">
                <span class="install-step-num">2</span>
                <div class="install-step-body">
                    <div>Tap the
                        <span class="ios-share-chip">
                            <svg class="ios-share-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="8 6 12 2 16 6"/>
                                <line x1="12" y1="2" x2="12" y2="15"/>
                                <path d="M20 14v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-5"/>
                            </svg>
                            Share
                        </span>
                        button at the bottom of Safari.
                    </div>
                </div>
            </li>
            <li class="install-step">
                <span class="install-step-num">3</span>
                <div class="install-step-body">
                    <div>Scroll down and tap
                        <span class="ios-share-chip ios-share-chip--add">
                            <span class="ios-share-plus">+</span>
                            Add to Home Screen
                        </span>
                    </div>
                </div>
            </li>
            <li class="install-step">
                <span class="install-step-num">4</span>
                <div class="install-step-body">
                    <div>Tap <strong>Add</strong> — Vivace will appear on your home screen like a real app!</div>
                </div>
            </li>
        </ol>

        <!-- Android steps — install.js shows this to Android visitors (fallback when
             beforeinstallprompt isn't available e.g. Firefox, Samsung, or already dismissed) -->
        <ol class="install-steps" id="installStepsAndroid" style="display:none;">
            <li class="install-step">
                <span class="install-step-num">1</span>
                <div class="install-step-body">
                    <div>Open this page in <strong>Chrome</strong> (or Edge / Samsung Internet).</div>
                </div>
            </li>
            <li class="install-step">
                <span class="install-step-num">2</span>
                <div class="install-step-body">
                    <div>Tap the
                        <span class="ios-share-chip">
                            <svg class="ios-share-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="5" r="1.6"/>
                                <circle cx="12" cy="12" r="1.6"/>
                                <circle cx="12" cy="19" r="1.6"/>
                            </svg>
                            Menu
                        </span>
                        button in the top-right of the browser.
                    </div>
                </div>
            </li>
            <li class="install-step">
                <span class="install-step-num">3</span>
                <div class="install-step-body">
                    <div>Tap
                        <span class="ios-share-chip ios-share-chip--add">
                            <span class="ios-share-plus">+</span>
                            Install app
                        </span>
                        or <strong>Add to Home screen</strong>.
                    </div>
                </div>
            </li>
            <li class="install-step">
                <span class="install-step-num">4</span>
                <div class="install-step-body">
                    <div>Tap <strong>Install</strong> — Vivace will appear on your home screen like a real app!</div>
                </div>
            </li>
        </ol>

        <div class="modal-buttons">
            <button class="btn-verify install-close-btn" id="installCloseBtn">Got it!</button>
        </div>
    </div>
</div>
