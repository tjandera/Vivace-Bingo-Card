# =========================================================================
# .env.example — booth code configuration.
#
# Copy this file to `.env` (never committed) for local dev, and add these
# same variables in the Vercel dashboard under Project Settings → Environment
# Variables for production.
#
# Only the codes below are secret — the hashes shipped to the browser are
# computed at server boot from these values.
# =========================================================================

# The mandatory "START HERE" booth (Vivace's Gamebooth)
BOOTH_CODE_B0=change-me

# Regular booths
BOOTH_CODE_B1=change-me
BOOTH_CODE_B2=change-me
BOOTH_CODE_B3=change-me
BOOTH_CODE_B4=change-me
BOOTH_CODE_B5=change-me
BOOTH_CODE_B6=change-me
BOOTH_CODE_B7=change-me
BOOTH_CODE_B8=change-me
BOOTH_CODE_B9=change-me
BOOTH_CODE_B10=change-me
BOOTH_CODE_B11=change-me
